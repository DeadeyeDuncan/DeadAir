<Window x:Class="DeadAir.App.RecordingIndicatorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="320" Height="76"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False" ShowActivated="False"
        IsHitTestVisible="False" Focusable="False">
    <!-- Ember plate: translucent warm black at the center easing to the deep
         blood-red rim (user smoke: flat red read too bright; red lives at the
         edges only). Alphas keep the pill slightly see-through. -->
    <Border CornerRadius="18">
        <Border.Background>
            <RadialGradientBrush>
                <GradientStop Color="#C8060404" Offset="0"/>
                <GradientStop Color="#D30E0505" Offset="0.7"/>
                <GradientStop Color="#E0200807" Offset="1"/>
            </RadialGradientBrush>
        </Border.Background>
        <Grid Margin="12,8">
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="20"/>
            </Grid.RowDefinitions>
            <Canvas x:Name="ScopeCanvas" Grid.Row="0" Width="296" Height="40"
                    ClipToBounds="True">
                <!-- Lantern phosphor double-stroke (spec 2026-07-16): soft wide
                     glow under a thin bright core; both share the same Points.
                     WPF has no additive compositing for strokes — layered
                     translucent strokes approximate the canvas 'lighter' pass. -->
                <Polyline x:Name="GlowLine" Stroke="#98180F" StrokeThickness="3.5"
                          StrokeLineJoin="Round" StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round" Opacity="0.30"/>
                <Polyline x:Name="ScopeLine" Stroke="#E8382B" StrokeThickness="1.3"
                          StrokeLineJoin="Round" StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round" Opacity="0.95"/>
                <!-- Nebula skin (spec 2026-07-17 redesign): 9px haze under a
                     6-strand DeadEye connection bundle; StrandHot is the brightest-red
                     core strand. Only one skin's elements are Visible (SetSkin). -->
                <Polyline x:Name="HazeLine" Stroke="#98180F" StrokeThickness="9"
                          StrokeLineJoin="Round" StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round" Opacity="0.05"
                          Visibility="Collapsed"/>
                <Polyline x:Name="Strand1" Stroke="#C11D12" StrokeThickness="0.85"
                          StrokeLineJoin="Round" StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round" Opacity="0.34"
                          Visibility="Collapsed"/>
                <Polyline x:Name="Strand2" Stroke="#C11D12" StrokeThickness="0.85"
                          StrokeLineJoin="Round" StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round" Opacity="0.34"
                          Visibility="Collapsed"/>
                <Polyline x:Name="Strand3" Stroke="#C11D12" StrokeThickness="0.85"
                          StrokeLineJoin="Round" StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round" Opacity="0.34"
                          Visibility="Collapsed"/>
                <Polyline x:Name="Strand4" Stroke="#C11D12" StrokeThickness="0.85"
                          StrokeLineJoin="Round" StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round" Opacity="0.34"
                          Visibility="Collapsed"/>
                <Polyline x:Name="Strand5" Stroke="#C11D12" StrokeThickness="0.85"
                          StrokeLineJoin="Round" StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round" Opacity="0.34"
                          Visibility="Collapsed"/>
                <Polyline x:Name="StrandHot" Stroke="#E8382B" StrokeThickness="1.1"
                          StrokeLineJoin="Round" StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round" Opacity="0.62"
                          Visibility="Collapsed"/>
                <Ellipse x:Name="BeamPip" Width="11" Height="11"
                         Visibility="Collapsed" IsHitTestVisible="False">
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="#FFFFF9F0" Offset="0"/>
                            <GradientStop Color="#CCC11D12" Offset="0.45"/>
                            <GradientStop Color="#00C11D12" Offset="1"/>
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                </Ellipse>
            </Canvas>
            <!-- TextAlignment=Right: a wide-glyph line that overflows the 296px
                 row in pixels must spill off the stale LEFT edge — LeftElide
                 guarantees the newest (rightmost) words stay visible. -->
            <TextBlock x:Name="InterimText" Grid.Row="1" FontSize="12"
                       FontStyle="Italic" Foreground="#66E1F5FE"
                       TextTrimming="None" TextWrapping="NoWrap"
                       TextAlignment="Right"/>
        </Grid>
    </Border>
</Window>
